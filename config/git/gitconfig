[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true

[diff]
	algorithm = histogram

[merge]
	conflictStyle = zdiff3

[core]
	pager = delta
	fsmonitor = true
	untrackedcache = true

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD
	unstage = reset HEAD --
	amend = commit --amend --no-edit
