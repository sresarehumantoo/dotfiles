#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

COMPACT_MODE=false
VHDX_PATH_OVERRIDE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            header "wsl-resize-disk"
            echo "Compact the WSL2 virtual disk (ext4.vhdx)."
            echo "Runs fstrim inside WSL, enables sparse mode, reports disk"
            echo "sizes, and offers compaction options."
            echo ""
            echo "Options:"
            echo "  -h, --help          Show this help"
            echo "  --compact           Generate a .bat script that compacts the"
            echo "                      disk via export/re-import (no admin required)"
            echo "  --vhdx-path PATH    Use a specific VHDX file instead of"
            echo "                      auto-detecting (accepts WSL or Windows paths)"
            exit 0
            ;;
        --compact) COMPACT_MODE=true ;;
        --vhdx-path)
            [[ -z "${2:-}" ]] && die "--vhdx-path requires a path argument"
            VHDX_PATH_OVERRIDE="$2"
            shift
            ;;
        *) die "Unknown option: $1" ;;
    esac
    shift
done

require_wsl

# ── Resolve the VHDX path for the current distro ───────────────
distro="${WSL_DISTRO_NAME:-}"

if [[ -n "$VHDX_PATH_OVERRIDE" ]]; then
    step "Using specified VHDX path..."
    # Accept both Windows and WSL paths
    if [[ "$VHDX_PATH_OVERRIDE" =~ ^[A-Za-z]:\\ ]]; then
        vhdx_path=$(wslpath "$VHDX_PATH_OVERRIDE")
    else
        vhdx_path="$VHDX_PATH_OVERRIDE"
    fi
    [[ -f "$vhdx_path" ]] || die "VHDX file not found: $vhdx_path"
    vhdx_win=$(wslpath -w "$vhdx_path")
    vhdx_dir_win=$(wslpath -w "$(dirname "$vhdx_path")")
    ok "Using VHDX: $vhdx_win"
else
    step "Resolving VHDX path..."
    localappdata=$(cmd.exe /C "echo %LOCALAPPDATA%" 2>/dev/null | tr -d '\r')
    [[ -z "$localappdata" ]] && die "Could not determine Windows LOCALAPPDATA path."
    packages_wsl=$(wslpath "$localappdata")/Packages

    # Find all VHDX files, then prefer the one matching this distro
    mapfile -t all_vhdx < <(find "$packages_wsl" -maxdepth 3 -name 'ext4.vhdx' -path "*LocalState*" 2>/dev/null)
    [[ ${#all_vhdx[@]} -eq 0 ]] && die "Could not locate ext4.vhdx under $packages_wsl"

    vhdx_path=""
    if [[ -n "$distro" ]]; then
        for candidate in "${all_vhdx[@]}"; do
            if echo "$candidate" | grep -qi "$distro"; then
                vhdx_path="$candidate"
                break
            fi
        done
    fi
    # Fallback to the first match if distro filtering didn't hit
    [[ -z "$vhdx_path" ]] && vhdx_path="${all_vhdx[0]}"

    vhdx_win=$(wslpath -w "$vhdx_path")
    vhdx_dir_win=$(wslpath -w "$(dirname "$vhdx_path")")
    ok "Detected VHDX: $vhdx_win"
fi

# ── Size reporting ──────────────────────────────────────────────
header "Disk usage"

vhdx_size_bytes=$(stat -c%s "$vhdx_path" 2>/dev/null || echo 0)
vhdx_size_mb=$(( vhdx_size_bytes / 1048576 ))
info "VHDX file size: ${vhdx_size_mb} MB ($(( vhdx_size_mb / 1024 )) GB)"

# Show actual filesystem usage inside WSL
used_mb=$(df -BM --output=used / 2>/dev/null | tail -1 | tr -d ' M')
total_mb=$(df -BM --output=size / 2>/dev/null | tail -1 | tr -d ' M')
if [[ -n "$used_mb" && -n "$total_mb" ]]; then
    info "Filesystem usage: ${used_mb} MB used of ${total_mb} MB total"
    savings=$(( vhdx_size_mb - used_mb ))
    if (( savings > 100 )); then
        info "Potential savings: ~${savings} MB"
    fi
fi

# ── Trim ────────────────────────────────────────────────────────
header "Trimming unused blocks"
sudo fstrim -av
ok "Trim complete"

# ── Sparse mode ─────────────────────────────────────────────────
header "Enabling sparse mode"
if wsl.exe --manage "${distro:-$WSL_DISTRO_NAME}" --set-sparse true 2>/dev/null; then
    ok "Sparse mode enabled — WSL will automatically reclaim disk space going forward."
else
    warn "Could not enable sparse mode (requires WSL 2.0.4+). Skipping."
fi

# ── Compaction ──────────────────────────────────────────────────
if $COMPACT_MODE; then
    header "Generating compaction script"

    read -r -d '' bat_content <<BAT || true
@echo off
setlocal

set DISTRO=${distro}
set VHDX_DIR=${vhdx_dir_win}
set TMPDIR=%TEMP%\\wslcompact

echo ============================================================
echo  WSL Disk Compaction - %DISTRO%
echo ============================================================
echo.
echo  Original VHDX: %VHDX_DIR%\\ext4.vhdx
echo  Original size:  ${vhdx_size_mb} MB
echo.
echo  This will export and re-import your distro to create a
echo  fresh, compacted disk image. No admin required.
echo.
echo  WARNING: WSL will be shut down during this process.
echo  Close any running WSL sessions before continuing.
echo.
pause

echo.
echo Shutting down WSL...
wsl --shutdown
timeout /t 3 /nobreak >nul

echo Cleaning up any previous temp files...
if exist "%TMPDIR%" rmdir /s /q "%TMPDIR%"
mkdir "%TMPDIR%"

echo.
echo Compacting %DISTRO% (export + re-import)...
echo This may take several minutes depending on disk size.
echo.
wsl --export "%DISTRO%" - | wsl --import wslcompact "%TMPDIR%" -

if not exist "%TMPDIR%\\ext4.vhdx" (
    echo.
    echo ERROR: Compaction failed - no image produced.
    echo Original image is unchanged.
    wsl --unregister wslcompact >nul 2>&1
    if exist "%TMPDIR%" rmdir /s /q "%TMPDIR%"
    pause
    exit /b 1
)

for %%A in ("%TMPDIR%\\ext4.vhdx") do set NEWSIZE=%%~zA
set /a NEWSIZE_MB=%NEWSIZE% / 1048576
set /a SAVED_MB=${vhdx_size_mb} - %NEWSIZE_MB%

echo.
echo ============================================================
echo  Original:  ${vhdx_size_mb} MB
echo  Compacted: %NEWSIZE_MB% MB
echo  Saved:     %SAVED_MB% MB
echo ============================================================
echo.

set /p CONFIRM=Replace original image with compacted version? (y/N):
if /i not "%CONFIRM%"=="y" (
    echo.
    echo Cancelled. Cleaning up temp files...
    wsl --unregister wslcompact >nul 2>&1
    rmdir /s /q "%TMPDIR%"
    pause
    exit /b 0
)

echo.
echo Unregistering temp distro...
wsl --unregister wslcompact >nul 2>&1

echo Replacing original image...
copy /y "%TMPDIR%\\ext4.vhdx" "%VHDX_DIR%\\ext4.vhdx"

if errorlevel 1 (
    echo.
    echo ERROR: Could not replace the original image.
    echo The compacted image is still at: %TMPDIR%\\ext4.vhdx
    echo You can manually copy it to: %VHDX_DIR%\\ext4.vhdx
    pause
    exit /b 1
)

echo Cleaning up...
rmdir /s /q "%TMPDIR%"

echo.
echo ============================================================
echo  Done! Starting %DISTRO%...
echo ============================================================
wsl -d %DISTRO%
BAT

    write_bat "wsl-compact.bat" "$bat_content"
else
    header "Compaction options"

    info "Option 1: Export/re-import (no admin required)"
    echo ""
    echo "      wsl-resize-disk --compact"
    echo ""
    info "   Generates a .bat script that compacts the disk by"
    info "   exporting and re-importing your distro. Safe, no"
    info "   admin privileges needed."
    echo ""

    rule

    echo ""
    info "Option 2: Optimize-VHD / diskpart (admin required)"
    echo ""
    info "   Shut down WSL, then run from elevated PowerShell:"
    echo ""
    echo "      wsl --shutdown"
    echo ""
    echo "      # PowerShell (Hyper-V module):"
    echo "      Optimize-VHD -Path \"$vhdx_win\" -Mode Full"
    echo ""
    echo "      # Or via diskpart:"
    echo "      diskpart"
    echo "      select vdisk file=\"$vhdx_win\""
    echo "      attach vdisk readonly"
    echo "      compact vdisk"
    echo "      detach vdisk"

    echo ""
    ok "WSL side complete. Choose an option above to finish compaction."
fi
