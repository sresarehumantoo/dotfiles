#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

SCRIPT_MODE=false
for arg in "$@"; do
    case "$arg" in
        -h|--help)
            header "wsl-resize-disk"
            echo "Compact the WSL2 virtual disk (ext4.vhdx)."
            echo "Runs fstrim inside WSL, enables sparse mode, then prints"
            echo "instructions for the Windows-side compaction step."
            echo ""
            echo "Options:"
            echo "  -h, --help    Show this help"
            echo "  --script      Generate a PowerShell script instead of"
            echo "                printing manual instructions"
            exit 0
            ;;
        --script) SCRIPT_MODE=true ;;
    esac
done

require_wsl

# Resolve the VHDX path for the current distro
step "Resolving VHDX path..."
localappdata=$(cmd.exe /C "echo %LOCALAPPDATA%" 2>/dev/null | tr -d '\r')
[[ -z "$localappdata" ]] && die "Could not determine Windows LOCALAPPDATA path."
packages_wsl=$(wslpath "$localappdata")/Packages

# Find all VHDX files, then prefer the one matching this distro
mapfile -t all_vhdx < <(find "$packages_wsl" -maxdepth 3 -name 'ext4.vhdx' -path "*LocalState*" 2>/dev/null)
[[ ${#all_vhdx[@]} -eq 0 ]] && die "Could not locate ext4.vhdx under $packages_wsl"

distro="${WSL_DISTRO_NAME:-}"
vhdx_path=""
if [[ -n "$distro" ]]; then
    for candidate in "${all_vhdx[@]}"; do
        if echo "$candidate" | grep -qi "$distro"; then
            vhdx_path="$candidate"
            break
        fi
    done
fi
# Fallback to the first match if distro filtering didn't hit
[[ -z "$vhdx_path" ]] && vhdx_path="${all_vhdx[0]}"

vhdx_win=$(wslpath -w "$vhdx_path")

ok "Detected VHDX: $vhdx_win"

header "Trimming unused blocks"
sudo fstrim -av
ok "Trim complete"

# Enable sparse mode for automatic disk reclamation
header "Enabling sparse mode"
if wsl.exe --manage "${distro:-$WSL_DISTRO_NAME}" --set-sparse true 2>/dev/null; then
    ok "Sparse mode enabled — WSL will automatically reclaim disk space going forward."
else
    warn "Could not enable sparse mode (requires WSL 2.0.4+). Skipping."
fi

header "Non-elevated alternative"
info "If you don't have access to an elevated Windows prompt,"
info "you can use wslcompact (no admin required):"
echo ""
echo "   Install-Module -Name WslCompact"
echo "   WslCompact"
echo ""
info "See: https://github.com/okibcn/wslcompact"

if $SCRIPT_MODE; then
    header "Generating PowerShell script"

    # Escape backslashes for the PS1 content (vhdx_win already uses backslashes)
    read -r -d '' ps1_content <<PS1 || true
# wsl-resize-disk.ps1
# Compacts the WSL2 virtual disk after fstrim has been run inside WSL.
# Run from an elevated (Administrator) PowerShell.

Write-Host "Shutting down WSL..." -ForegroundColor Cyan
wsl --shutdown
Start-Sleep -Seconds 2

\$vhdxPath = "${vhdx_win}"

# Try Optimize-VHD first (requires Hyper-V PowerShell module)
try {
    Write-Host "Compacting with Optimize-VHD..." -ForegroundColor Cyan
    Optimize-VHD -Path \$vhdxPath -Mode Full
    Write-Host "Compaction complete." -ForegroundColor Green
} catch {
    Write-Host "Optimize-VHD not available, falling back to diskpart..." -ForegroundColor Yellow
    \$diskpartScript = @"
select vdisk file="\$vhdxPath"
attach vdisk readonly
compact vdisk
detach vdisk
"@
    \$tmpFile = [System.IO.Path]::GetTempFileName()
    Set-Content -Path \$tmpFile -Value \$diskpartScript
    diskpart /s \$tmpFile
    Remove-Item \$tmpFile
    Write-Host "Compaction complete (diskpart)." -ForegroundColor Green
}

# Restart the distro
Write-Host "Starting WSL distro: ${distro}..." -ForegroundColor Cyan
wsl -d ${distro}
PS1

    write_ps1 "wsl-resize-disk.ps1" "$ps1_content"
else
    header "Next: compact from elevated PowerShell"
    info "1. Shut down WSL:"
    echo "      wsl --shutdown"
    echo ""
    info "2. Run one of the following:"
    echo ""
    echo "   # PowerShell (Hyper-V module):"
    echo "   Optimize-VHD -Path \"$vhdx_win\" -Mode Full"
    echo ""
    echo "   # Or via diskpart:"
    echo "   diskpart"
    echo "   select vdisk file=\"$vhdx_win\""
    echo "   attach vdisk readonly"
    echo "   compact vdisk"
    echo "   detach vdisk"

    echo ""
    info "Tip: use --script to generate a PowerShell script you can run directly."
    echo ""
    ok "WSL side complete. Follow the steps above in Windows to finish."
fi
