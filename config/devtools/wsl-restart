#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

SCRIPT_MODE=false
for arg in "$@"; do
    case "$arg" in
        -h|--help)
            header "wsl-restart"
            echo "Restart WSL from within WSL."
            echo "This will terminate all WSL sessions immediately."
            echo ""
            echo "Options:"
            echo "  -h, --help    Show this help"
            echo "  --script      Generate a PowerShell script instead of"
            echo "                shutting down from within WSL"
            exit 0
            ;;
        --script) SCRIPT_MODE=true ;;
    esac
done

require_wsl

distro="${WSL_DISTRO_NAME:-}"

if $SCRIPT_MODE; then
    header "Generating PowerShell script"

    read -r -d '' ps1_content <<PS1 || true
# wsl-restart.ps1
# Restarts the current WSL distro.
# Run from PowerShell (does not require elevation).

Write-Host "Shutting down WSL..." -ForegroundColor Cyan
wsl --shutdown
Start-Sleep -Seconds 2
Write-Host "Starting WSL distro: ${distro}..." -ForegroundColor Cyan
wsl -d ${distro}
PS1

    write_ps1 "wsl-restart.ps1" "$ps1_content"
else
    warn "This will shut down WSL and terminate all sessions."
    confirm "Continue?" || { info "Aborted."; exit 0; }

    step "Shutting down WSL..."
    wsl.exe --shutdown
fi
