# dfinstall configuration
# Auto-generated after first install run.
# Lives at <dotfiles>/.config.yaml

# Skip automatic backups on install (set to false to backup every time)
skip_backup: true

# Custom backup directory (default: ~/.local/share/dfinstall/backups)
# backup_dir: /path/to/backups

# Extended OMZ plugins (selected via dfinstall install omz --extended)
# extended_plugins:
#   - kubectl
#   - aws
#   - sudo

# Skip specific modules during 'install all' / 'update all'
# skip_modules:
#   - wsl
#   - fonts

# Shell files preserved when the shell module replaces ~/.zshrc
# (managed automatically via interactive prompt on first install)
# preserved_files:
#   - .companyrc
#   - .work_env

# Shell files the user chose NOT to preserve (won't be prompted again)
# dismissed_files:
#   - .old_aliases
